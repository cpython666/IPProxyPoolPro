# API
IP_PROXY_POOL_API_PORT=8888
IP_PROXY_POOL_TEST_WORKERS=1

# Redis
IP_PROXY_POOL_DB_CONNECT_TYPE=redis
IP_PROXY_POOL_REDIS_HOST=localhost
IP_PROXY_POOL_REDIS_PORT=6379
IP_PROXY_POOL_REDIS_DB=0
IP_PROXY_POOL_REDIS_PASSWORD=
IP_PROXY_POOL_REDIS_KEY=proxies

# Proxy source crawling
IP_PROXY_POOL_SOURCE_REGION=all
IP_PROXY_POOL_FETCH_TIMEOUT=15
IP_PROXY_POOL_FETCH_CONCURRENCY=5
IP_PROXY_POOL_SOURCE_URL_CACHE_SECONDS=14400
IP_PROXY_POOL_SOURCE_DYNAMIC_MAX_PAGES=0
IP_PROXY_POOL_PRECHECK_BEFORE_ADD=1
IP_PROXY_POOL_PRECHECK_CONCURRENCY=20
IP_PROXY_POOL_PRECHECK_CACHED_SOURCE_PROXIES=1
IP_PROXY_POOL_PRECHECK_FAIL_CACHE_SECONDS=14400

# Proxy validation
IP_PROXY_POOL_REQUEST_CLIENT=requests
IP_PROXY_POOL_TEST_SITE=httpbin
IP_PROXY_POOL_TEST_URL=
IP_PROXY_POOL_DECREASE_STEP=1
